# Task Configuration

# Available options:
# easy_001   → basic dependency + logs
# easy_002   → memory / OOM issue
# easy_003   → disk full / logging issue
# medium_001 → multi-service cascade debugging
# hard_001   → complex cascading failure

TASK_ID=easy_001
SEED=42